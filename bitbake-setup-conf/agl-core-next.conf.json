{
    "version": "1.0",
    "name": "agl-core",
    "description": "AGL Core platform build using bitbake-setup",
    "sources": {
        "bitbake": {
            "git-remote": {
                "uri": "https://git.openembedded.org/bitbake",
                "branch": "2.18",
                "rev": "2.18"
            }
        },
        "openembedded-core": {
            "git-remote": {
                "uri": "https://git.openembedded.org/openembedded-core",
                "branch": "wrynose",
                "rev": "wrynose",
                "layers": [
                    "meta"
                ]
            }
        },
        "meta-openembedded": {
            "git-remote": {
                "uri": "https://git.openembedded.org/meta-openembedded",
                "branch": "master",
                "rev": "master",
                "layers": [
                    "meta-oe",
                    "meta-python",
                    "meta-networking"
                ]
            }
        },
        "meta-agl": {
            "git-remote": {
                "uri": "https://gerrit.automotivelinux.org/gerrit/AGL/meta-agl",
                "branch": "next",
                "rev": "next",
                "layers": [
                    "meta-agl-core"
                ]
            }
        }
    },
    "bitbake-setup": {
        "configurations": [
        {
            "name": "AGL",
            "description": "AGL master",
            "setup-dir-name": "agl-master",
            "bb-layers": ["openembedded-core/meta",
                          "meta-openembedded/meta-oe",
                          "meta-openembedded/meta-python",
                          "meta-openembedded/meta-networking",
                          "meta-agl/meta-agl-core"
            ],
            "oe-fragments-one-of": {
                "machine": {
                    "description": "Target machines",
                    "options" : [
                        { "name": "machine/qemux86-64", "description": "x86-64 system on QEMU" },
                        { "name": "machine/qemuarm64", "description": "ARMv8 system on QEMU" }
                    ]
                }
            }
        }
        ]
    }
}
